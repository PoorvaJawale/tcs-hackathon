# ── Fake Internship Offer Detector — environment variables ──
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real keys.

# OpenAI — entity extraction + fraud explanation (structured outputs)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: override the model used for extraction/reasoning
# (defaults in code to gpt-4o-mini if unset)
OPENAI_MODEL=gpt-4o-mini

# Tavily — company/domain search + site verification
# Get one at: https://app.tavily.com/home
TAVILY_API_KEY=tvly-...

# Optional: Microsoft Presidio analyzer REST endpoint for NER-grade PII
# redaction before any text is sent to OpenAI/Tavily. Run locally with:
#   docker run -p 5002:3000 mcr.microsoft.com/presidio-analyzer
# If unset, a built-in regex redactor (Aadhaar/PAN/cards/phones/emails) is used.
# PRESIDIO_ANALYZER_URL=http://localhost:5002

# ── App settings (optional, sensible defaults in code) ──
# Max offer text length accepted by /api/analyze (characters)
MAX_TEXT_LENGTH=15000

# Max upload size for PDF/DOCX in bytes (5MB)
MAX_FILE_SIZE=5242880

# Basic per-IP rate limit for analyze endpoints (requests per minute)
RATE_LIMIT_PER_MINUTE=10
